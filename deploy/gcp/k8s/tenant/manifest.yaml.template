apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: gemcode-tenant-__TENANT_ID__
  namespace: gemcode-tenants
  labels:
    gemcode.io/tenant-id: "__TENANT_ID__"
    app.kubernetes.io/part-of: gemcode-hosting
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: __PVC_SIZE__
  storageClassName: standard-rwo
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: gemcode-tenant-__TENANT_ID__
  namespace: gemcode-tenants
  labels:
    gemcode.io/tenant-id: "__TENANT_ID__"
    app.kubernetes.io/name: gemcode-tenant
    app.kubernetes.io/part-of: gemcode-hosting
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      gemcode.io/tenant-id: "__TENANT_ID__"
  template:
    metadata:
      labels:
        gemcode.io/tenant-id: "__TENANT_ID__"
        app.kubernetes.io/name: gemcode-tenant
    spec:
      serviceAccountName: default
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      containers:
        - name: gemcode
          image: __TENANT_IMAGE__
          imagePullPolicy: Always
          ports:
            - name: http
              containerPort: 3001
          env:
            - name: GEMCODE_HOSTED_TENANT_ROOT
              value: /mnt/workspace
            - name: GEMCODE_WEB_PROJECT_ROOT
              value: /mnt/workspace
            - name: GEMCODE_HOME
              value: /mnt/workspace/.gemcode
            - name: GEMCODE_SUPER_MODE
              value: "1"
            - name: GEMCODE_MODEL
              value: gemini-3.1-pro-preview
            - name: GOOGLE_API_KEY
              valueFrom:
                secretKeyRef:
                  name: gemcode-gemini-api-key
                  key: GOOGLE_API_KEY
                  optional: true
          resources:
            requests:
              cpu: __CPU_REQUEST__
              memory: __MEM_REQUEST__
            limits:
              cpu: __CPU_LIMIT__
              memory: __MEM_LIMIT__
          volumeMounts:
            - name: workspace
              mountPath: /mnt/workspace
          readinessProbe:
            httpGet:
              path: /api/health
              port: http
            initialDelaySeconds: 10
            periodSeconds: 15
          livenessProbe:
            httpGet:
              path: /api/health
              port: http
            initialDelaySeconds: 30
            periodSeconds: 30
      volumes:
        - name: workspace
          persistentVolumeClaim:
            claimName: gemcode-tenant-__TENANT_ID__
---
apiVersion: v1
kind: Service
metadata:
  name: gemcode-tenant-__TENANT_ID__
  namespace: gemcode-tenants
  labels:
    gemcode.io/tenant-id: "__TENANT_ID__"
spec:
  type: ClusterIP
  selector:
    gemcode.io/tenant-id: "__TENANT_ID__"
  ports:
    - name: http
      port: 3001
      targetPort: http
