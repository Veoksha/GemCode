# Copy to config.env and edit before running setup scripts.
export GCP_PROJECT_ID="finai-474319"
export GCP_REGION="us-central1"
export GKE_CLUSTER_NAME="gemcode-hosting"
export ARTIFACT_REGISTRY_REPO="gemcode"
export GEMCODE_NAMESPACE="gemcode-platform"
export TENANTS_NAMESPACE="gemcode-tenants"

# PyPI version when not building from repo source
export GEMCODE_PIP_VERSION="0.4.24"

# Image tags (Artifact Registry)
export GEMCODE_TENANT_IMAGE="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${ARTIFACT_REGISTRY_REPO}/gemcode-tenant:latest"
export GEMCODE_PROVISIONER_IMAGE="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${ARTIFACT_REGISTRY_REPO}/gemcode-provisioner:latest"
export GEMCODE_GATEWAY_IMAGE="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${ARTIFACT_REGISTRY_REPO}/gemcode-tenant-gateway:latest"
export GEMCODE_WEB_UI_IMAGE="${GCP_REGION}-docker.pkg.dev/${GCP_PROJECT_ID}/${ARTIFACT_REGISTRY_REPO}/gemcode-web-ui:latest"

# Tenant defaults
export TENANT_PVC_SIZE="30Gi"
export TENANT_CPU_REQUEST="500m"
export TENANT_CPU_LIMIT="2"
export TENANT_MEM_REQUEST="1Gi"
export TENANT_MEM_LIMIT="4Gi"
