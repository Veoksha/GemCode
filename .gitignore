# Local bootstrap script (machine-specific paths; keep your own copy)
run-gemcode-tui.sh

.pytest_cache/
**/.pytest_cache/
.env
.gemcode/
*.sqlite
veomem/.venv/
veomem/**/__pycache__/
veomem/**/*.pyc
**/*.egg-info/

# Python build artifacts
**/__pycache__/
**/*.pyc
gemcode/dist/
gemcode/build/
gemcode/*.egg-info/

# Web UI / editor clients (separate repos — not part of the gemcode PyPI package)
# Official or custom frontends connect via `gemcode serve` on :3001 (see docs/web-ui-contract.md).
gemcode-web-ui/
gemcode-web-ui/.env.local
gemcode-web-api/
gemcode-vscode/
gemcode-vscode/node_modules/
gemcode-vscode/*.vsix
veomem/
openclaude/
