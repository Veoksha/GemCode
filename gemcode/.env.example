# Google AI Studio (default): https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Model id (Gemini API)
GEMCODE_MODEL=gemini-3-flash-preview

# Model mode selector:
# - `fast`: use GEMCODE_MODEL
# - `quality`: use GEMCODE_MODEL_QUALITY (fallback to GEMCODE_MODEL if unset)
# - `balanced`: use GEMCODE_MODEL_BALANCED (fallback to GEMCODE_MODEL if unset)
# - `auto`: heuristically pick the best model for the prompt
GEMCODE_MODEL_MODE=fast

# Alternate model ids used by `quality` / `balanced` modes.
GEMCODE_MODEL_QUALITY=gemini-3.1-pro-preview
GEMCODE_MODEL_BALANCED=gemini-3.1-flash-lite-preview

# Alternate model ids (Gemini 2.5 family) for `model_family_mode`.
# Used to complement Gemini 3.x defaults when prompts are simpler or when
# you explicitly force this family.
GEMCODE_MODEL_FAMILY_MODE=auto
GEMCODE_MODEL_ALT=gemini-2.5-flash
GEMCODE_MODEL_ALT_QUALITY=gemini-2.5-pro
GEMCODE_MODEL_ALT_BALANCED=gemini-2.5-flash-lite

# Optional: computer use (ADK ComputerUseToolset)
# GEMCODE_ENABLE_COMPUTER_USE=1
# GEMCODE_COMPUTER_HEADLESS=1   # 1=true, 0=false (browser automation)
# GEMCODE_MODEL_COMPUTER_USE=gemini-2.5-computer-use-preview-10-2025

# Optional: audio mode routing (used by `gemcode live-audio`)
# GEMCODE_ENABLE_AUDIO=1   # (only meaningful for live-audio in this MVP)
# GEMCODE_MODEL_AUDIO_LIVE=gemini-3.1-flash-live-preview

# Capability routing (enables toolsets + routes models):
# - `auto`: prompt heuristics (research/tools/computer actions)
# - `research|embeddings|computer|audio|all`: force corresponding capabilities
# GEMCODE_CAPABILITY_MODE=auto

# Gemini 3 tool context circulation (built-in tools + custom/function tools
# combination):
# - deep_research: enable only when GEMCODE_ENABLE_DEEP_RESEARCH=1
# - always: enable for Gemini 3.x regardless of deep research toggle
# - never: disable always
# - auto: alias for deep_research
# GEMCODE_TOOL_COMBINATION_MODE=deep_research

# Optional: deep research routing (enables research tools + deep-research model)
# GEMCODE_ENABLE_DEEP_RESEARCH=1
# GEMCODE_MODEL_DEEP_RESEARCH=travel_explore

# Optional: Google Maps grounding inside deep research.
# This is opt-in because it can be incompatible with other built-in tools
# (e.g., Google Search) depending on the model/tooling layer.
# GEMCODE_ENABLE_MAPS_GROUNDING=1

# Optional: embeddings-based semantic retrieval
# GEMCODE_ENABLE_EMBEDDINGS=1
# GEMCODE_EMBEDDINGS_MODEL=models/gemini-embedding-2-preview

# Permission: strict | default (strict denies writes/shell unless allowlisted)
GEMCODE_PERMISSION_MODE=default

# Optional: enable in-run HITL approval prompt for mutating tools and computer-use actions.
# When enabled and you did NOT pass `--yes`, GemCode prompts in the current run
# instead of requiring a re-run with --yes.
# GEMCODE_INTERACTIVE_PERMISSION_ASK=1

# Enable persistent memory ingestion/retrieval (file-backed under .gemcode/).
# GEMCODE_ENABLE_MEMORY=1
# GEMCODE_MEMORY_FILE=.gemcode/memories.jsonl  # (fixed in code for MVP)

# Allow shell commands as "executable" names (comma-separated). Empty = none in strict; default adds common dev tools.
# GEMCODE_ALLOW_COMMANDS=pytest,python3,npm,git,ruff

# Trim conversation contents before each model call if too many Content entries (MVP compaction)
GEMCODE_MAX_CONTENT_ITEMS=40
# GEMCODE_ENABLE_COMPACT=0

# Stop after this many consecutive tool errors (circuit breaker; session state)
GEMCODE_MAX_CONSECUTIVE_TOOL_FAILURES=8

# Claude-like recovery retry on tool failures (ReflectAndRetryToolPlugin)
# GEMCODE_ENABLE_TOOL_RECOVERY_RETRY=1
# GEMCODE_TOOL_REFLECT_MAX_RETRIES=1

# Cap model↔tool iterations per user message (ADK RunConfig.max_llm_calls). Omit = SDK default.
# GEMCODE_MAX_LLM_CALLS=64

# Hard stop before the next LLM call when cumulative usage_metadata totals exceed this (session).
# GEMCODE_MAX_SESSION_TOKENS=800000

# Per-message token budget for continuation logging (query/token_budget.py); resets each user turn.
# GEMCODE_TOKEN_BUDGET=500000

# Optional post-turn executable (or use .gemcode/hooks/post_turn)
# GEMCODE_POST_TURN_HOOK=/path/to/hook.sh

# Use Gemini Interactions API to generate (chained) prompt suggestions
# instead of sending full history in a second request.
# GEMCODE_PROMPT_SUGGESTIONS_USE_INTERACTIONS=1

# Gemini thinking configuration
# - Gemini 3.x: supports `thinkingLevel` (can't fully disable; minimal approximates)
# - Gemini 2.5: supports `thinkingBudget` (0 disables for supported models)
# Claude-like behavior: thinking is enabled by default unless explicitly disabled
# GEMCODE_DISABLE_THINKING=0
# GEMCODE_INCLUDE_THOUGHT_SUMMARIES=0
# GEMCODE_THINKING_LEVEL=minimal|low|medium|high
# GEMCODE_THINKING_BUDGET=0|-1|1024

# Optional: Vertex AI (see gemcode/vertex.py)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
