# Google AI Studio (default): https://aistudio.google.com/app/apikey
# After `pip install gemcode`, run `gemcode login` once to save a key under
# ~/.gemcode/credentials.json (overridden by env vars and this .env).
GOOGLE_API_KEY=

# Print full tracebacks for model API failures to stderr (debug).
# GEMCODE_VERBOSE_MODEL_ERRORS=1

# Extra system prompt: disciplined change quality (ambiguity, minimal scope, surgical diffs). Default on.
# GEMCODE_ENGINEERING_DISCIPLINE=0

# ADK Gemini context cache (reuses compiled prefix; lower input cost on long sessions).
# Set to 0 to disable server-side cachedContents entirely (higher token use, no cache-delete edge cases).
# GEMCODE_CONTEXT_CACHE=0

# Model id (Gemini API)
GEMCODE_MODEL=gemini-3-flash-preview

# Model mode selector:
# - `fast`: use GEMCODE_MODEL
# - `quality`: use GEMCODE_MODEL_QUALITY (fallback to GEMCODE_MODEL if unset)
# - `balanced`: use GEMCODE_MODEL_BALANCED (fallback to GEMCODE_MODEL if unset)
# - `auto`: heuristically pick the best model for the prompt
GEMCODE_MODEL_MODE=fast

# Alternate model ids used by `quality` / `balanced` modes.
GEMCODE_MODEL_QUALITY=gemini-3.1-pro-preview
GEMCODE_MODEL_BALANCED=gemini-3.1-flash-lite-preview

# Alternate model ids (Gemini 2.5 family) for `model_family_mode`.
# Used to complement Gemini 3.x defaults when prompts are simpler or when
# you explicitly force this family.
GEMCODE_MODEL_FAMILY_MODE=auto
GEMCODE_MODEL_ALT=gemini-2.5-flash
GEMCODE_MODEL_ALT_QUALITY=gemini-2.5-pro
GEMCODE_MODEL_ALT_BALANCED=gemini-2.5-flash-lite

# Optional: computer use (ADK ComputerUseToolset)
# GEMCODE_ENABLE_COMPUTER_USE=1
# GEMCODE_COMPUTER_HEADLESS=1   # 1=true, 0=false (browser automation)
# GEMCODE_MODEL_COMPUTER_USE=gemini-2.5-computer-use-preview-10-2025

# Optional: audio mode routing (used by `gemcode live-audio`)
# GEMCODE_ENABLE_AUDIO=1   # (only meaningful for live-audio in this MVP)
# GEMCODE_MODEL_AUDIO_LIVE=gemini-3.1-flash-live-preview

# Capability routing (enables toolsets + routes models):
# - `auto`: prompt heuristics (research/tools/computer actions)
# - `research|embeddings|computer|audio|all`: force corresponding capabilities
# GEMCODE_CAPABILITY_MODE=auto

# Gemini 3 tool context circulation (built-in tools + custom/function tools
# combination):
# - deep_research: enable only when GEMCODE_ENABLE_DEEP_RESEARCH=1
# - always: enable for Gemini 3.x regardless of deep research toggle
# - never: disable always
# - auto: alias for deep_research
# GEMCODE_TOOL_COMBINATION_MODE=deep_research

# Optional: deep research routing (enables research tools + deep-research model)
# GEMCODE_ENABLE_DEEP_RESEARCH=1
# GEMCODE_MODEL_DEEP_RESEARCH=<your_deep_research_model_id>

# Optional: Google Maps grounding inside deep research.
# This is opt-in because it can be incompatible with other built-in tools
# (e.g., Google Search) depending on the model/tooling layer.
# GEMCODE_ENABLE_MAPS_GROUNDING=1

# Optional: embeddings-based semantic retrieval
# GEMCODE_ENABLE_EMBEDDINGS=1
# GEMCODE_EMBEDDINGS_MODEL=models/gemini-embedding-2-preview

# Permission: strict | default (strict denies writes/shell unless allowlisted)
GEMCODE_PERMISSION_MODE=default

# Optional: enable in-run HITL approval prompt for mutating tools and computer-use actions.
# When enabled and you did NOT pass `--yes`, GemCode prompts in the current run
# instead of requiring a re-run with --yes.
# GEMCODE_INTERACTIVE_PERMISSION_ASK=1

# Super mode: maximum autonomy — auto-approve GemCode tool gates, skip AFC stdin tool prompt,
# non-interactive get_user_choice (first option), auto-trust on CLI, etc.
# Same as: gemcode --super   or   REPL /super   or   gemcode runtime --super
# GEMCODE_SUPER_MODE=1

# After you approve one tool, skip further HITL prompts for this session (default: on).
# Set to 0 to require approval for every single tool call (ADK default behavior without this).
# GEMCODE_HITL_STICKY_SESSION=0

# TUI: optionally run Kaira inside the same terminal UI (no second terminal needed).
# When enabled, GemCode starts a headless Kaira daemon (IPC-only) and shows its
# job output inline in the GemCode TUI (`gemcode/tui/scrollback.py`).
# GEMCODE_TUI_WITH_KAIRA=1

# Fleet report inbox: append completed org/job/agent reports to .gemcode/fleet_reports.jsonl
# and prepend to the next manager turn (plain REPL + GemCode TUI).
# GEMCODE_FLEET_REPORTS_INJECT=0
# GEMCODE_FLEET_REPORTS_MAX_CHARS=14000
# Hands-off digest: extra manager turns and/or debounced runtime job (see docs/orchestration.md).
# GEMCODE_FLEET_REPORTS_AUTO_CONTINUE=1
# GEMCODE_FLEET_REPORTS_AUTO_CONTINUE_MODE=tui
# GEMCODE_FLEET_REPORTS_AUTO_CONTINUE_MAX=3
# GEMCODE_FLEET_REPORTS_ENQUEUE_DEBOUNCE_S=0.45

# Kaira: local scheduled automations.
# - Place configs at: .gemcode/automations/*.json
# - Enable scheduling: GEMCODE_AUTOMATIONS=1 (or `gemcode kaira --automations`)
# - Optional heartbeat: enqueue a prompt every N seconds.
# GEMCODE_AUTOMATIONS=1
# GEMCODE_KAIRA_HEARTBEAT_EVERY_S=240
# GEMCODE_KAIRA_HEARTBEAT_PROMPT=Heartbeat: summarise XAUUSD monitor status

# AFC tool-mode prompt (interactive only). When non-callable toolsets are present (MCP/OpenAPI),
# AFC tool-mode stdin prompt (MCP/OpenAPI non-callables). Default: no prompt — keep all tools.
# GEMCODE_AFC_PROMPT=1           # set to ask afc> (all vs callable-only)
# GEMCODE_AFC_DEFAULT=all        # when PROMPT=1: skip afc> and preselect all|callables

# Enable persistent memory ingestion/retrieval (file-backed under .gemcode/).
# GEMCODE_ENABLE_MEMORY=1
# GEMCODE_MEMORY_FILE=.gemcode/memories.jsonl  # (fixed in code for MVP)

# Allow shell commands as "executable" names (comma-separated). Empty = none in strict; default adds common dev tools.
# GEMCODE_ALLOW_COMMANDS=pytest,python3,npm,git,ruff

# Context hygiene: cap tool output + soft prompt text budget before each model call.
# GEMCODE_TOOL_RESULT_MAX_CHARS=12000
# GEMCODE_MAX_CONTEXT_CHARS=400000
# Set to 0 to disable only the pre-model text shrink (sliding-window compaction is separate).
# GEMCODE_CONTEXT_SHRINK=0

# Autocompact: summarize older turns when near context ceiling.
# GEMCODE_AUTOCOMPACT=1
# GEMCODE_AUTOCOMPACT_BUFFER_CHARS=60000
# GEMCODE_AUTOCOMPACT_KEEP_CONTENT_ITEMS=18
# GEMCODE_AUTOCOMPACT_MAX_FAILURES=3
# GEMCODE_AUTOCOMPACT_MODEL=gemini-2.5-flash   # optional: cheaper summarizer

# Context window for threshold math (tokens). Unset → heuristic by model family.
# GEMCODE_CONTEXT_WINDOW_TOKENS=1000000
# Default buffers (tokens) for /context and stderr warnings:
# GEMCODE_AUTOCOMPACT_BUFFER_TOKENS=13000
# GEMCODE_CONTEXT_WARNING_BUFFER_TOKENS=20000
# GEMCODE_CONTEXT_ERROR_BUFFER_TOKENS=20000
# GEMCODE_CONTEXT_BLOCKING_BUFFER_TOKENS=3000
# Set to 0 to silence [gemcode context] stderr lines after each model call.
# GEMCODE_CONTEXT_WARNINGS=1

# Trim conversation contents before each model call if too many Content entries (MVP compaction)
GEMCODE_MAX_CONTENT_ITEMS=40
# GEMCODE_ENABLE_COMPACT=0

# Stop after this many consecutive tool errors (circuit breaker; session state)
GEMCODE_MAX_CONSECUTIVE_TOOL_FAILURES=8

# Recovery retry on tool failures (ReflectAndRetryToolPlugin)
# GEMCODE_ENABLE_TOOL_RECOVERY_RETRY=1
# GEMCODE_TOOL_REFLECT_MAX_RETRIES=1

# Cap model↔tool iterations per user message (ADK RunConfig.max_llm_calls).
# Omit or empty → GemCode defaults to 256 (agentic multi-step turns).
# GEMCODE_MAX_LLM_CALLS=128

# Hard stop before the next LLM call when cumulative usage_metadata totals exceed this (session).
# GEMCODE_MAX_SESSION_TOKENS=800000

# Per-message token budget for continuation logging (query/token_budget.py); resets each user turn.
# GEMCODE_TOKEN_BUDGET=500000

# Optional: one-shot retry after model “context too large / length” errors.
# This tightens GEMCODE_MAX_CONTEXT_CHARS + GEMCODE_TOOL_RESULT_MAX_CHARS
# and re-runs the same prompt.
# GEMCODE_ENABLE_MODEL_ERROR_RETRY=1
# GEMCODE_MODEL_ERROR_RETRY_MAX_ATTEMPTS=2   # 2 = first attempt + 1 retry
# GEMCODE_MODEL_ERROR_RETRY_SHRINK_FACTOR=0.6

# Optional post-turn executable (or use .gemcode/hooks/post_turn)
# GEMCODE_POST_TURN_HOOK=/path/to/hook.sh

# Use Gemini Interactions API to generate (chained) prompt suggestions
# instead of sending full history in a second request.
# GEMCODE_PROMPT_SUGGESTIONS_USE_INTERACTIONS=1

# Gemini thinking configuration
# - Gemini 3.x: supports `thinkingLevel` (can't fully disable; minimal approximates)
# - Gemini 2.5: supports `thinkingBudget` (0 disables for supported models)
# Default: thinking is enabled unless explicitly disabled
# GEMCODE_DISABLE_THINKING=0
# GEMCODE_INCLUDE_THOUGHT_SUMMARIES=0
# GEMCODE_THINKING_LEVEL=minimal|low|medium|high
# GEMCODE_THINKING_BUDGET=0|-1|1024

# Optional: Vertex AI (see gemcode/vertex.py)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
